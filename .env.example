# ============================================================
# Chatrium AI — environment variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# ============================================================

# ---- Runtime ----
NODE_ENV=development
PORT=3000

# ---- Anthropic ----
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx
# Default model — override per-environment if needed
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Database ----
# Phase 1 can run without DB. Phase 2+ requires this.
DATABASE_URL=mysql://chatrium_app:changeme@localhost:3306/chatrium_ai

# ---- Auth (Phase 2+) ----
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000
AUTH_EMAIL_FROM=noreply@chatrium.com

# ---- SMTP for magic-link (Phase 2+) ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@chatrium.com
SMTP_PASS=

# ---- Cost ceiling (฿) ----
COST_CEILING_THB_PER_USER_MONTH=50
COST_SOFT_ALERT_THB_PER_USER_MONTH=30

# ---- Observability ----
LOG_LEVEL=info
